# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Where the app is hosted (used for share links, QR codes, and emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (optional — signups still work without it, emails are just skipped)
RESEND_API_KEY=
# Use your verified domain once you have one, e.g. "SignupDingus <signups@yourchurch.org>"
EMAIL_FROM=SignupDingus <onboarding@resend.dev>
